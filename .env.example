# =============================================================================
# SmartSeat — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables are optional — defaults are provided.

# --- Server ---
API_HOST=0.0.0.0
API_PORT=5000
API_RELOAD=false          # Set to "true" only for local development
LOG_LEVEL=info            # debug | info | warning | error | critical
CORS_ORIGINS=*            # Comma-separated allowed origins, e.g. "http://localhost:3000,https://example.com"

# --- Data paths ---
# DATA_DIR=./data         # Directory for train data and simulation state
# QR_DIR=./qr_codes       # Directory for generated QR code images

# --- Data generation ---
DATA_SEED=42              # Random seed for reproducible data generation

# --- ML model ---
ML_MAX_DEPTH=6            # Decision tree max depth
ML_RANDOM_STATE=42        # ML model random seed
ML_TRAINING_SAMPLES=500   # Number of synthetic training samples
